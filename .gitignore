# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.claude/settings.local.json

# react-doctor regó skill files en directorios de muchos agentes IA al
# correr `react-doctor install`. Solo conservamos .claude/skills (Claude
# Code, que es lo que usamos). El resto es ruido para este proyecto.
.claude/worktrees/
.agents/
/skills/
.codebuddy/
.commandcode/
.continue/
.crush/
.factory/
.goose/
.kilocode/
.kiro/
.mcpjam/
.mux/
.neovate/
.openhands/
