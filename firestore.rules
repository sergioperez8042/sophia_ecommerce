rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the current user an admin?
    // Admin se identifica por su doc en users/{uid} con role == 'admin'.
    // Usamos exists() antes de get() para que la regla no se rompa si por
    // alguna razón el doc del propio admin no existe (e.g. cuenta huérfana).
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Products - TEMPORARILY OPEN FOR MIGRATION
    match /products/{productId} {
      allow read: if true;
      allow write: if true;
    }

    // Categories - TEMPORARILY OPEN FOR MIGRATION
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if true;
    }

    // Config - anyone can read and write catalog configuration
    match /config/{document} {
      allow read: if true;
      allow write: if true;
    }

    // Users - authenticated can read, create allowed for account setup.
    // Update/delete: el propio usuario, o un admin (necesario para que el
    // admin pueda enlazar cuenta de gestor al doc users/{gestorUid}, lo cual
    // es un setDoc que cae como update si el doc ya existe).
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (
        request.auth.uid == userId || isAdmin()
      );
    }

    // Orders
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Subscribers - anyone can read/create (needed for duplicate check on subscribe), only authenticated can manage
    match /subscribers/{subscriberId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // Newsletters - only authenticated users can read/write
    match /newsletters/{newsletterId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Gestores - anyone can read (needed for gestor matching in cart), only authenticated can manage
    match /gestores/{gestorId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Reviews - anyone can read, authenticated users can create, only own reviews can be deleted
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
  }
}
