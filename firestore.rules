rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Products - anyone can read, only authenticated users can write
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Categories - anyone can read, only authenticated users can write
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Config - anyone can read and write catalog configuration
    match /config/{document} {
      allow read: if true;
      allow write: if true;
    }

    // Users - authenticated can read, create allowed for account setup, update/delete own doc only
    // Admin creates user docs when setting up gestor accounts (uid != userId)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Orders
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Subscribers - anyone can read/create (needed for duplicate check on subscribe), only authenticated can manage
    match /subscribers/{subscriberId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // Newsletters - only authenticated users can read/write
    match /newsletters/{newsletterId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Gestores - anyone can read (needed for gestor matching in cart), only authenticated can manage
    match /gestores/{gestorId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Reviews - anyone can read, authenticated users can create, only own reviews can be deleted
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
  }
}
